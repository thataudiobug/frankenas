---
# tasks file for pve_dl_ct
- name: Check if Proxmox Container Exists
  community.proxmox.proxmox_vm_info:
    node: pve
    api_user: robot@pam
    api_host: 192.168.1.100
    api_token_id: "{{ api_catalog.pve_api.id }}"
    api_token_secret: "{{ api_catalog.pve_api.key }}"
    name: '{{ inventory_hostname }}'
    type: lxc
  register: does_vm

- name: Build New Proxmox Containers
  community.proxmox.proxmox:
    node: pve
    api_user: robot@pam
    api_host: 192.168.1.100
    api_token_id: "{{ api_catalog.pve_api.id }}"
    api_token_secret: "{{ api_catalog.pve_api.key }}"
    hostname: '{{ inventory_hostname }}'
    ostemplate: "{{ os_catalog[os_enabled]['ct_template'] }}"
    cores: "{{ compute_catalog[compute_enabled]['cores'] }}"
    memory: "{{ compute_catalog[compute_enabled]['memory_mb'] }}"
    disk_volume:
      storage: "{{ storage_catalog[storage_enabled]['disk_type'] }}"
      size: "{{ storage_catalog[storage_enabled]['disk_size_gb'] }}"
    pubkey: >
      {{ users_enabled
        | select('in', users_catalog)
        | map('extract', users_catalog, 'key')
        | join('\n') }}
    netif:
      net0: "name=eth0,gw={{ network_catalog[network_enabled]['gateway'] }},ip={{ ansible_host }}/{{ network_catalog[network_enabled]['subnet'] }},bridge={{ network_catalog[network_enabled]['bridge'] }},firewall=0"
    features:
      - "nesting=1"
    description: " Last rebuilt by script at {{ now() | string }}"
    state: present
  register: was_built
  when: does_vm.proxmox_vms[0] is not defined

- name: Remove Stale known_hosts Entries for Rebuilt Container
  command: ssh-keygen -R "{{ item }}"
  loop:
    - "{{ inventory_hostname }}"
    - "{{ ansible_host }}"
  when:
    - was_built.changed
    - inventory_hostname != ansible_host
  delegate_to: localhost
  changed_when: false
  failed_when: false

- name: Wait for buildout to complete
  pause:
    seconds: 10
  when: was_built is changed

- name: Add GPU Mappings
  community.proxmox.proxmox:
    node: pve
    api_user: robot@pam
    api_host: 192.168.1.100
    api_token_id: "{{ api_catalog.pve_api.id }}"
    api_token_secret: "{{ api_catalog.pve_api.key }}"
    hostname: '{{ inventory_hostname }}'
    features:
      - "nesting=1"
      - "lxc.cgroup2.devices.allow: c 226:128 rwm"
      - "lxc.mount.entry: /dev/dri/renderD128 dev/dri/renderD128 none bind,optional,create=file"
      - 'lxc.hook.pre-start: sh -c \"chown 100000:100993 /dev/dri/renderD128\"'
    state: present
  when: gpu_enabled is true

- name: Start Container
  community.proxmox.proxmox:
    node: pve
    api_user: robot@pam
    api_host: 192.168.1.100
    api_token_id: "{{ api_catalog.pve_api.id }}"
    api_token_secret: "{{ api_catalog.pve_api.key }}"
    hostname: '{{ inventory_hostname }}'
    state: started
  register: was_started

- name: Wait for Container to Become Available
  wait_for:
    host: "{{ ansible_host }}"
    port: 22
    timeout: 30
  delegate_to: localhost
