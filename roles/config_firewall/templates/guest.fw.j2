#{{ ansible_managed }}
# Proxmox guest firewall for {{ inventory_hostname }} (vmid {{ _fw_vmid }}),
# profile '{{ firewall_enabled }}'. Managed by the config_firewall role — edit the
# firewall_catalog / firewall_overrides, not this file.
#
# Enforced on the host side of the guest's veth. This filters the WAN NIC
# (firewall=1); the OOB management NIC is left unfiltered (firewall=0) so
# SSH/Ansible/API over {{ config_firewall_guest_mgmt_cidr }} can never be locked out.

[OPTIONS]
enable: 1
policy_in: {{ _fw.policy_in | default('DROP') }}
policy_out: {{ _fw.policy_out | default('ACCEPT') }}
{% if _fw.log_level_in is defined %}
log_level_in: {{ _fw.log_level_in }}
{% endif %}
{% if _fw.log_level_out is defined %}
log_level_out: {{ _fw.log_level_out }}
{% endif %}

[RULES]
{% if config_firewall_guest_inject_mgmt_ssh | bool %}
# Auto-injected: SSH from the OOB management network. Belt-and-suspenders —
# the OOB NIC is already unfiltered, but this guarantees reachability even
# if someone flips OOB to firewall=1. Always first so it wins.
IN ACCEPT -source {{ config_firewall_guest_mgmt_cidr }} -p tcp -dport {{ config_firewall_guest_ssh_port }} -log nolog # mgmt SSH (config_firewall safety)
{% endif %}
{% for rule in _fw.rules | default([]) %}
{{ rule.type | default('in') | upper }} {{ rule.action }}{% if rule.iface is defined %} -i {{ rule.iface }}{% endif %}{% if rule.source is defined %} -source {{ rule.source }}{% endif %}{% if rule.dest is defined %} -dest {{ rule.dest }}{% endif %}{% if rule.proto is defined %} -p {{ rule.proto }}{% endif %}{% if rule.dport is defined %} -dport {{ rule.dport }}{% endif %}{% if rule.sport is defined %} -sport {{ rule.sport }}{% endif %}{% if rule.log is defined %} -log {{ rule.log }}{% endif %}{% if rule.comment is defined %} # {{ rule.comment }}{% endif %}

{% endfor %}
