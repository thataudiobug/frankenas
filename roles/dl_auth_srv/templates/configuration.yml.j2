---
# {{ ansible_managed }}
#
# Authelia configuration for Orthax (managed by dl_auth_srv). Edit the role
# vars / authelia_access_catalog / auth_srv_users, not this file.
#
# Secrets are injected here from the vault. The file is mode 0640 and the
# templating task is no_log; treat it as sensitive.

server:
  address: 'tcp://:{{ auth_srv_port }}'

log:
  level: 'info'
  format: 'json'   # structured, so Loki/Grafana can parse auth events

totp:
  # TOTP issuer shown in authenticator apps. Per-resource factor level
  # (one_factor vs two_factor) is set by the access_control rules below —
  # there is no per-user 2FA flag; the sensitive resource forces enrolment.
  issuer: '{{ auth_srv_totp_issuer }}'

identity_validation:
  reset_password:
    jwt_secret: '{{ auth_srv_jwt_secret }}'

authentication_backend:
  # How often Authelia re-checks LDAP for user/group updates.
  refresh_interval: '{{ auth_srv_ldap_refresh_interval }}'
  ldap:
    # Built-in LLDAP template: sets the user/group filters + attribute
    # mappings for LLDAP automatically. Only connection + bind details here.
    implementation: '{{ auth_srv_ldap_implementation }}'
    address: '{{ auth_srv_ldap_address }}'
    base_dn: '{{ auth_srv_ldap_base_dn }}'
    user: '{{ auth_srv_ldap_bind_dn }}'
    password: '{{ auth_srv_ldap_bind_password }}'

# Self-service password change/reset. Requires the LLDAP bind account to hold
# the lldap_password_manager permission; otherwise set both to disable: true.
password_reset:
  disable: {{ auth_srv_password_reset_disable | string | lower }}
password_change:
  disable: {{ auth_srv_password_change_disable | string | lower }}

access_control:
  default_policy: '{{ auth_srv_default_policy }}'
  rules:
{% for rule in authelia_access_catalog %}
    - domain: '{{ rule.domain }}'
      policy: '{{ rule.policy | default("deny") }}'
{% if rule.subject is defined %}
      subject:
{% if rule.subject is string %}
        - '{{ rule.subject }}'
{% else %}
{% for s in rule.subject %}
        - '{{ s }}'
{% endfor %}
{% endif %}
{% endif %}
{% if rule.resources is defined %}
      resources:
{% for r in rule.resources %}
        - '{{ r }}'
{% endfor %}
{% endif %}
{% if rule.networks is defined %}
      networks:
{% for n in rule.networks %}
        - '{{ n }}'
{% endfor %}
{% endif %}
{% endfor %}

session:
  secret: '{{ auth_srv_session_secret }}'
  cookies:
    - name: 'authelia_session'
      domain: '{{ auth_srv_root_domain }}'
      authelia_url: '{{ auth_srv_portal_url }}'
      expiration: '{{ auth_srv_session_expiration }}'
      inactivity: '{{ auth_srv_session_inactivity }}'
  redis:
    host: 'redis'
    port: {{ auth_srv_redis_port }}
    password: '{{ auth_srv_redis_password }}'

regulation:
  max_retries: {{ auth_srv_regulation_max_retries }}
  find_time: '{{ auth_srv_regulation_find_time }}'
  ban_time: '{{ auth_srv_regulation_ban_time }}'

storage:
  encryption_key: '{{ auth_srv_storage_encryption_key }}'
  local:
    path: '/config/db.sqlite3'

notifier:
  # File notifier: password-reset / 2FA-enrolment links are written to a
  # file instead of emailed (no SMTP dependency to start). Tail it on the
  # host when enrolling a user. Swap for smtp later.
  filesystem:
    filename: '/config/notification.txt'
