# {{ ansible_managed }}
#
# Authelia enforcement snippet (managed by service_reverse_proxy).
#
# Include this INSIDE the location block of a proxy host you want to protect
# (NPM "Advanced" config). It runs the auth_request against /authelia, and on
# a 401 redirects the user to the Authelia portal with a return URL.

auth_request /authelia;

# Pull the authenticated user/groups Authelia returns and forward them to
# the upstream app (apps that understand these headers get SSO identity).
auth_request_set $user $upstream_http_remote_user;
auth_request_set $groups $upstream_http_remote_groups;
auth_request_set $name $upstream_http_remote_name;
auth_request_set $email $upstream_http_remote_email;
proxy_set_header Remote-User $user;
proxy_set_header Remote-Groups $groups;
proxy_set_header Remote-Name $name;
proxy_set_header Remote-Email $email;

# On an unauthenticated/unauthorized response, send the browser to the
# Authelia portal, preserving where it was trying to go.
auth_request_set $redirection_url $upstream_http_location;
error_page 401 =302 {{ service_reverse_proxy_authelia_portal_url }}/?rd=$scheme://$http_host$request_uri;
