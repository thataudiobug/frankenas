# {{ ansible_managed }}
# Env file for the piracy compose stack on {{ inventory_hostname }}.
# Rendered mode 0600, no_log — carries vault VPN credentials. compose
# interpolates these into piracy compose.yml as ${VARS}.

# -- VPN provider env (resolved from vpn_provider_catalog -> the selected
#    vpn_provider_enabled entry, with custom_ovpn already stripped). Emitted
#    verbatim so each provider contributes EXACTLY its own gluetun vars —
#    a custom provider yields OPENVPN_CUSTOM_CONFIG, PIA yields SERVER_REGIONS
#    + VPN_PORT_FORWARDING, etc. No provider-specific keys hardcoded here.
{% for k, v in _piracy_vpn.items() %}
{{ k }}={{ v }}
{% endfor %}

# -- Kill switch: allow the OOB mgmt net out so the web UI stays reachable
#    from OOB even if the tunnel drops.
FIREWALL=on
FIREWALL_OUTBOUND_SUBNETS={{ vpn_outbound_subnets | default('10.128.0.0/9') }}

# -- Common
PUID={{ piracy_puid | default('1000') }}
PGID={{ piracy_pgid | default('1000') }}
TZ={{ piracy_tz | default('america/detroit') }}
