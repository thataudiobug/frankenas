docker_catalog:
  - name: jellyfin
    image: jellyfin/jellyfin:latest
    ports:
      - "8096:8096"
    devices: /dev/dri:/dev/dri
    volumes:
      - "{{ transcodes_path }}:/cache"
      - "{{ media_path }}:/media"
      - "{{ config_path }}/jellyfin/config:/config"

  - name: ombi
    image: linuxserver/ombi:latest
    env:
      PUID: 1000
      PGID: 1000
    ports:
      - "3579:3579"
    volumes:
      - "{{ config_path }}/ombi:/config"

  - name: npm
    image: jc21/nginx-proxy-manager:latest
    ports:
      - "81:81"
      - "80:80"
      - "443:443"
    volumes:
      - "{{ config_path }}/npm/data:/data"
      - "{{ config_path }}/npm/letsencrypt:/etc/letsencrypt"

  - name: termix
    image: ghcr.io/lukegus/termix:latest
    env:
      PUID: 1000
      PGID: 1000
      ENABLE_SSL: true
      SSL_KEY_PATH: /app/data/ssl/termix.key
      SSL_CERT_PATH: /app/data/ssl/termix.crt
      SSL_PORT: 8443
    ports:
      - "8443:8443"
    volumes:
      - "{{ config_path }}termix:/app/data"

  - name: nextcloud
    image: lscr.io/linuxserver/nextcloud:latest
    env:
      PUID: 1000
      PGID: 1000
    ports:
      - "6549:443"
    volumes:
      - "{{ config_path }}/nextcloud:/config"
      - "{{ backup_storage }}/nextcloud:/data"
      - "{{ fast_storage }}:/caleb"
      - "{{ big_storage }}:/essek"
      - "{{ slow_storage }}:/nott"
      - "{{ backup_storage }}:/yasha"

  - name: prowlarr
    image: linuxserver/prowlarr:latest
    env:
      PUID: 1000
      PGID: 1000
    ports:
      - "9696:9696"
    volumes:
      - "{{ config_path }}/prowlarr:/config"

  - name: radarr
    image: linuxserver/radarr:latest
    env:
      PUID: 1000
      PGID: 1000
    ports:
      - "8989:8989"
    volumes:
      - "{{ config_path }}/radarr:/config"
      - "{{ media_path }}/movies:/movies"
      - "{{ media_path }}/downloads:/downloads"
