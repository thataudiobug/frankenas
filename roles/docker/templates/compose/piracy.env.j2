# {{ ansible_managed }}
# Env file for the piracy compose stack on {{ inventory_hostname }}.
# Rendered mode 0600, no_log — carries vault VPN credentials. compose
# interpolates these into piracy compose.yml as ${VARS}.

# -- VPN provider (resolved from vpn_provider_catalog -> vpn_provider_enabled)
VPN_SERVICE_PROVIDER={{ _piracy_vpn.VPN_SERVICE_PROVIDER | default('custom') }}
VPN_TYPE={{ _piracy_vpn.VPN_TYPE | default('openvpn') }}
OPENVPN_USER={{ _piracy_vpn.OPENVPN_USER | default('') }}
OPENVPN_PASSWORD={{ _piracy_vpn.OPENVPN_PASSWORD | default('') }}
OPENVPN_CUSTOM_CONFIG={{ _piracy_vpn.OPENVPN_CUSTOM_CONFIG | default('/gluetun/custom.ovpn') }}

# -- Kill switch: allow the OOB mgmt net out so the web UI stays reachable
#    from OOB even if the tunnel drops.
FIREWALL_OUTBOUND_SUBNETS={{ vpn_outbound_subnets | default('10.128.0.0/9') }}

# -- Common
PUID={{ piracy_puid | default('0') }}
PGID={{ piracy_pgid | default('0') }}
TZ={{ piracy_tz | default('america/detroit') }}
