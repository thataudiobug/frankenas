# {{ ansible_managed }}
#
# Loki config for the central log server (Mollymauk). Single-binary mode,
# filesystem storage on the Nott bind, {{ service_loki_retention_period }}
# retention. Managed by service_loki — edit the role vars, not this file.

auth_enabled: false   # NOTE: this is multi-tenancy, NOT access control.
                      # Loki is unauthenticated; it is kept safe by binding
                      # to OOB only + the config_firewall rule on :{{ service_loki_loki_http_port }}.

server:
  http_listen_port: {{ service_loki_loki_http_port }}
  grpc_listen_port: {{ service_loki_loki_grpc_port }}
  log_level: info

common:
  instance_addr: 127.0.0.1
  path_prefix: /loki
  storage:
    filesystem:
      chunks_directory: {{ service_loki_data_root }}/chunks
      rules_directory: {{ service_loki_data_root }}/rules
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: 2024-01-01
      store: tsdb
      object_store: filesystem
      schema: v13
      index:
        prefix: index_
        period: 24h

storage_config:
  filesystem:
    directory: {{ service_loki_data_root }}/chunks
  tsdb_shipper:
    active_index_directory: {{ service_loki_data_root }}/index
    cache_location: {{ service_loki_data_root }}/index_cache

compactor:
  working_directory: {{ service_loki_data_root }}/compactor
  # Required for retention to actually delete data (not just mark it).
  retention_enabled: {{ service_loki_retention_enabled | bool | lower }}
  delete_request_store: filesystem

limits_config:
  retention_period: {{ service_loki_retention_period }}
  # Generous-ish ingestion limits for a homelab fleet; raise if you see
  # 429s from the agents under burst.
  ingestion_rate_mb: 16
  ingestion_burst_size_mb: 32
  reject_old_samples: true
  reject_old_samples_max_age: 168h

ruler:
  storage:
    type: local
    local:
      directory: {{ service_loki_data_root }}/rules
