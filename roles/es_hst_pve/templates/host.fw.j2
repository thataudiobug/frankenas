#{{ ansible_managed }}
# Node (host) Proxmox firewall for {{ inventory_hostname }}. Managed by
# es_hst_pve. Restricts the node's own management surfaces — web UI :8006,
# SSH, API, consoles — to the OOB network ({{ pve_node_mgmt_cidr }}). WAN
# exposure of these services is denied by the DROP input policy.

[OPTIONS]
enable: 1
policy_in: DROP
policy_out: ACCEPT

[RULES]
# Management surfaces — OOB network only.
{% for p in pve_node_mgmt_ports %}
IN ACCEPT -source {{ pve_node_mgmt_cidr }} -p {{ p.proto }} -dport {{ p.port }}{% if p.comment is defined %} # {{ p.comment }}{% endif %}

{% endfor %}
{% if pve_node_cluster_peers | length > 0 %}
# Cluster / corosync links between nodes.
{% for peer in pve_node_cluster_peers %}
IN ACCEPT -source {{ peer }} -p udp -dport 5405:5412 # corosync
IN ACCEPT -source {{ peer }} -p tcp -dport 22 # node-to-node SSH/migration
{% endfor %}
{% endif %}
